# HQ-CLI is the test runner.

# Linux hosts.
HQ_SRV_IP=192.168.1.10
BR_SRV_IP=192.168.3.10
LINUX_SSH_USER=sshuser
LINUX_SSH_PASSWORD=P@ssw0rd
LINUX_SSH_PORT=2026

# ISP.
ISP_IP=172.16.1.1
ISP_SSH_USER=sshuser
ISP_SSH_PASSWORD=P@ssw0rd
ISP_SSH_PORT=22

# EcoRouter management addresses.
HQ_RTR_SSH_HOST=172.16.0.1
BR_RTR_SSH_HOST=192.168.3.1
ROUTER_SSH_USER=net_admin
ROUTER_SSH_PASSWORD=P@ssw0rd
ROUTER_SSH_PORT=22
ROUTER_ENABLE_PASSWORD=

# Router WAN addresses used by static NAT.
HQ_RTR_WAN_IP=172.16.1.4
BR_RTR_WAN_IP=172.16.2.5
HQ_WEB_EXTERNAL_PORT=8080
BR_APP_EXTERNAL_PORT=8080

# Samba.
DOMAIN_FQDN=au-team.irpo
DOMAIN_USER=hquser1
DOMAIN_USER_PREFIX=hquser
DOMAIN_USER_COUNT=5
DOMAIN_GROUP=hq

# RAID and NFS.
RAID_DEVICE=/dev/md0
RAID_LEVEL=0
RAID_MEMBER_COUNT=2
RAID_MOUNT=/raid
NFS_EXPORT=/raid/nfs
NFS_CLIENT_MOUNT=/mnt/nfs
HQ_CLI_SUBNET=192.168.2.0/28

# NTP.
NTP_STRATUM=5

# Docker application.
APP_CONTAINER=tespapp
DB_CONTAINER=db
APP_PORT=8080
APP_INTERNAL_PORT=8000
APP_DB_NAME=testdb
APP_DB_USER=testc
APP_DB_PASSWORD=P@ssw0rd

# Apache application.
WEB_PORT=80
WEB_DB_NAME=webdb
WEB_DB_USER=webc
WEB_DB_PASSWORD=P@ssw0rd

# Reverse proxy and authentication.
WEB_DOMAIN=web.au-team.irpo
DOCKER_DOMAIN=docker.au-team.irpo
AUTH_USER=WEB
AUTH_PASSWORD=P@ssw0rd

# Install only diagnostic packages when they are missing.
AUTO_INSTALL=yes
